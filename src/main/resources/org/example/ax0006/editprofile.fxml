<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800" prefWidth="1200" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <VBox layoutX="300" layoutY="40" prefWidth="520" spacing="16" style="-fx-background-color: white;                  -fx-background-radius: 12;                  -fx-padding: 30;                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 15, 0, 0, 4);">

        <!-- TÍTULO -->
        <Label style="-fx-font-size: 22px;                       -fx-font-weight: bold;                       -fx-text-fill: #2c3e50;" text="Editar Perfil" />

        <Separator />

        <!-- INFORMACIÓN GENERAL -->
        <VBox spacing="10">
            <Label style="-fx-font-weight: bold;                           -fx-text-fill: #7f8c8d;" text="Información General" />

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;                               -fx-text-fill: #2c3e50;" text="Nombre" />
                <TextField fx:id="ii_Nombre" prefHeight="36" promptText="Ingrese el nombre completo" style="-fx-background-color: white;                                   -fx-background-radius: 8;                                   -fx-border-color: #dcdfe3;                                   -fx-border-radius: 8;" text="Juan Pérez" />
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;                               -fx-text-fill: #2c3e50;" text="Correo" />
                <TextField fx:id="ii_Correo" prefHeight="36" promptText="Ingrese el correo electrónico" style="-fx-background-color: white;                                   -fx-background-radius: 8;                                   -fx-border-color: #dcdfe3;                                   -fx-border-radius: 8;" text="juan@gmail.com" />
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;                               -fx-text-fill: #2c3e50;" text="Rol" />
            <Label fx:id="lblRol" style="-fx-text-fill: #34495e;" text="Administrador" />
            </VBox>
        </VBox>

        <Separator />

        <!-- INFORMACIÓN DE CONTACTO -->
        <VBox spacing="10">
            <Label style="-fx-font-weight: bold;                           -fx-text-fill: #7f8c8d;" text="Información de Contacto" />

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;                               -fx-text-fill: #2c3e50;" text="Teléfono" />
                <TextField fx:id="ii_telefono" prefHeight="36" promptText="Ingrese el número de teléfono" style="-fx-background-color: white;                                   -fx-background-radius: 8;                                   -fx-border-color: #dcdfe3;                                   -fx-border-radius: 8;" text="+57 300 123 4567" />
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;                               -fx-text-fill: #2c3e50;" text="Dirección" />
                <TextArea fx:id="ii_direccion" prefHeight="70" promptText="Ingrese la dirección" style="-fx-background-color: white;                                  -fx-background-radius: 8;                                  -fx-border-color: #dcdfe3;                                  -fx-border-radius: 8;" text="Bogotá, Colombia" wrapText="true" />
            </VBox>
        </VBox>

        <Separator />

        <!-- CONTACTO DE EMERGENCIA -->
        <VBox spacing="10">
            <Label style="-fx-font-weight: bold;                           -fx-text-fill: #7f8c8d;" text="Contacto de Emergencia" />

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;                               -fx-text-fill: #2c3e50;" text="Nombre" />
                <TextField fx:id="ii_NombreEmergencia" prefHeight="36" promptText="Ingrese el nombre del contacto" style="-fx-background-color: white;                                   -fx-background-radius: 8;                                   -fx-border-color: #dcdfe3;                                   -fx-border-radius: 8;" text="María Pérez" />
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;                               -fx-text-fill: #2c3e50;" text="Teléfono" />
                <TextField fx:id="ii_TelefonoEmergencia" prefHeight="36" promptText="Ingrese el teléfono del contacto" style="-fx-background-color: white;                                   -fx-background-radius: 8;                                   -fx-border-color: #dcdfe3;                                   -fx-border-radius: 8;" text="+57 301 987 6543" />
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;                               -fx-text-fill: #2c3e50;" text="Relación" />
                <ComboBox fx:id="cb_RelacionEmergencia" prefHeight="36" promptText="Seleccione la relación" style="-fx-background-color: white;                                  -fx-background-radius: 8;                                  -fx-border-color: #dcdfe3;                                  -fx-border-radius: 8;" />
            </VBox>
        </VBox>

        <Separator />

        <!-- BOTONES -->
        <HBox spacing="10">
            <Button fx:id="bt_Guardar" onAction="#On_Guardar" prefHeight="38" prefWidth="150" style="-fx-background-color: #27ae60;                            -fx-text-fill: white;                            -fx-background-radius: 8;                            -fx-font-weight: bold;" text="Guardar" />

            <Button fx:id="bt_cancelar" onAction="#On_Cancelar" prefHeight="38" prefWidth="120" style="-fx-background-color: #bdc3c7;                            -fx-text-fill: #2c3e50;                            -fx-background-radius: 8;                            -fx-font-weight: bold;" text="Cancelar" />
        </HBox>

    </VBox>

</AnchorPane>
