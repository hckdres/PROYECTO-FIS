<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<Pane prefHeight="800.0" prefWidth="1200.0"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1">

    <children>

        <Text layoutX="380.0" layoutY="100.0" text="Crear Inventario + Asignar">
            <font><Font size="24.0"/></font>
        </Text>

        <!-- HORARIO -->
        <DatePicker fx:id="dp_fechaInicio" layoutX="400.0" layoutY="180.0"/>
        <DatePicker fx:id="dp_fechaFin" layoutX="600.0" layoutY="180.0"/>

        <TextField fx:id="tf_horaInicio" layoutX="400.0" layoutY="230.0" promptText="HH:mm"/>
        <TextField fx:id="tf_horaFin" layoutX="600.0" layoutY="230.0" promptText="HH:mm"/>

        <!-- CONTENEDOR DE OBJETOS -->
        <Label layoutX="400.0" layoutY="280.0" text="Objetos:"/>

        <VBox fx:id="contenedorObjetos"
              layoutX="400.0"
              layoutY="310.0"
              spacing="10.0"/>

        <!-- BOTÓN AGREGAR -->
        <Button fx:id="bt_agregarObjeto"
                layoutX="400.0"
                layoutY="450.0"
                text="Añadir otro objeto"
                onAction="#on_bt_agregarObjeto"/>

        <!-- CREAR -->
        <Button fx:id="bt_crear"
                layoutX="520.0"
                layoutY="500.0"
                text="Crear y Asignar"
                onAction="#on_bt_crear"/>

        <Label fx:id="lbl_msg"
               layoutX="520.0"
               layoutY="560.0"/>

        <Button fx:id="bt_volver"
                layoutX="1100.0"
                layoutY="740.0"
                text="Volver"
                onAction="#on_bt_volver"/>

    </children>
</Pane>