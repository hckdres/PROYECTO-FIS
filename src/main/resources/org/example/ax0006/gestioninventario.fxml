<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <HBox spacing="600" style="-fx-background-color: white; -fx-padding: 15;">
            <children>
                <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Gestión de Inventarios" />
                <Button onAction="#On_volver" text="Volver" />
            </children>
        </HBox>
    </top>
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <children>
                <TableView fx:id="tablaInventarios" prefHeight="500"
                           fixedCellSize="30" style="-fx-font-size: 16px;">
                    <columns>
                        <TableColumn fx:id="colNombre" prefWidth="200" text="Nombre" />
                        <TableColumn fx:id="colUbicacion" prefWidth="300" text="Ubicación" />
                    </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
                </TableView>
                <HBox spacing="10">
                    <children>
                        <TextField fx:id="txtNombreInventario" promptText="Nombre inventario" />
                        <TextField fx:id="txtUbicacion" promptText="Ubicación (Ej: Teatro Colón - Sala 1)" />
                        <Button onAction="#On_crearInventario" text="Crear" />
                        <Button onAction="#On_eliminarInventario" text="Eliminar" />
                        <Button onAction="#On_gestionarInventario" text="Gestionar" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
